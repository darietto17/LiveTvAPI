[{"title": "Alleluja e Sartana figli di... Dio", "start": 1772989729, "stop": 1772996209}, {"title": "Se incontri Sartana prega per la tua morte", "start": 1772996209, "stop": 1773001909}, {"title": "Il figlio di Zorro", "start": 1773001909, "stop": 1773007249}, {"title": "Ed ora... raccomanda l'anima a Dio!", "start": 1773007249, "stop": 1773012469}, {"title": "Con lui cavalca la morte", "start": 1773012469, "stop": 1773017252}, {"title": "La lunga cavalcata della vendetta", "start": 1773017252, "stop": 1773023012}, {"title": "La morte non conta i dollari", "start": 1773023012, "stop": 1773028592}, {"title": "Il Lungo Giorno Del Massacro", "start": 1773028592, "stop": 1773034928}, {"title": "...E per tetto un cielo di stelle", "start": 1773034928, "stop": 1773041048}, {"title": "Un treno per Durango", "start": 1773041048, "stop": 1773047348}]